</pre></td><td class="rouge-code"><pre><span class="c"># For Pod; adding --restart="Never" will make a pod</span>
kubectl run &lt;pod_name&gt; <span class="nt">--image</span> &lt;image_tag&gt; <span class="nt">--restart</span> Never
<span class="c"># For Deployment; omiting --restart will make a deployment</span>
kubectl run &lt;deployment_name&gt; <span class="nt">--image</span> &lt;image_tag&gt;
<span class="c"># For Job; adding --restart="OnFailure" will make a job</span>
kubectl run &lt;job_name&gt; <span class="nt">--image</span> &lt;image_tag&gt; <span class="nt">--restart</span> OnFailure
<span class="c"># For CronJobs; adding --restart="Onfailure" and an schedule will make a cronjob</span>
kubectl run &lt;job_name&gt; <span class="nt">--image</span> &lt;image_tag&gt; <span class="nt">--restart</span> OnFailure <span class="nt">--schedule</span><span class="o">=</span><span class="s2">"*/1 * * * *"</span>
</pre></td></tr></tbody></table></code></pre></div></div>

